{
  "name": "ng-b357",
  "version": "20.3.0",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "build": "ng build",
    "watch": "ng build --watch --configuration development",
    "test": "ng test",
    "lint": "ng lint",
    "reset": "rm -rf node_modules && rm -f pnpm-lock.yaml && pnpm install",
    "build:serve": "ng build && pnpm run serve",
    "serve": "pnpm dlx serve dist/ng-b357/browser -s",
    "caddy": "caddy start",
    "caddy:stop": "caddy stop",
    "build:sme": "ng b --source-map && pnpm run sme",
    "sme": "pnpm dlx source-map-explorer dist/ng-b357/browser/**/*.js --no-border-checks",
    "sme:html": "pnpm dlx source-map-explorer dist/ng-b357/browser/**/*.js --no-border-checks --only-mapped --html > ./dist/output.html",
    "build:vbv": "ng b --stats-json && pnpm run vbv",
    "vbv": "cd dist/ng-b357/browser && pnpm dlx vite-bundle-visualizer && cd ../../..",
    "build:wba": "ng b --stats-json && pnpm run wba",
    "wba": "pnpm dlx webpack-bundle-analyzer dist/ng-b357/stats.json",
    "igv": "pnpm dlx @rx-angular/import-graph-visualizer --entry-points src/main.ts --ts-config tsconfig.app.json",
    "dpdm": "pnpm dlx dpdm --no-warning --no-tree src/main.ts",
    "ng:update": "ng update @angular/cli @angular/core @angular/material angular-eslint",
    "e2e": "ng e2e --ui"
  },
  "private": true,
  "packageManager": "pnpm@11.5.2",
  "engines": {
    "node": ">=26 <27"
  },
  "dependencies": {
    "@angular-architects/paper-design": "^2.0.1",
    "@angular/animations": "^22.0.0",
    "@angular/cdk": "^22.0.0",
    "@angular/common": "^22.0.0",
    "@angular/compiler": "^22.0.0",
    "@angular/core": "^22.0.0",
    "@angular/forms": "^22.0.0",
    "@angular/material": "^22.0.0",
    "@angular/platform-browser": "^22.0.0",
    "@angular/platform-browser-dynamic": "^22.0.0",
    "@angular/platform-server": "^22.0.0",
    "@angular/router": "^22.0.0",
    "@angular/service-worker": "^22.0.0",
    "@angular/ssr": "^22.0.0",
    "@jsverse/transloco": "^8.1.0",
    "anychart": "^8.13.1",
    "express": "^5.1.0",
    "moment": "^2.30.1",
    "ngx-quicklink": "^0.4.8",
    "rxjs": "^7.8.2",
    "tslib": "^2.8.1",
    "zone.js": "~0.15.1"
  },
  "devDependencies": {
    "@angular-eslint/builder": "^21.4.0",
    "@angular/build": "^22.0.0",
    "@angular/cli": "^22.0.0",
    "@angular/compiler-cli": "^22.0.0",
    "@axe-core/playwright": "^4.11.0",
    "@playwright/test": "1.56.1",
    "@types/express": "^5.0.5",
    "@types/jasmine": "~5.1.12",
    "@types/node": "^25.9.2",
    "angular-eslint": "^21.4.0",
    "eslint": "^9.39.1",
    "eslint-config-prettier": "^10.1.8",
    "istanbul-lib-instrument": "^6.0.3",
    "jasmine-core": "~5.12.1",
    "karma": "~6.4.4",
    "karma-chrome-launcher": "~3.2.0",
    "karma-coverage": "~2.2.1",
    "karma-jasmine": "~5.1.0",
    "karma-jasmine-html-reporter": "~2.1.0",
    "playwright-ng-schematics": "2.1.1",
    "prettier": "^3.6.2",
    "source-map-explorer": "^2.5.3",
    "typescript": "~6.0.3",
    "typescript-eslint": "^8.46.3",
    "vite-bundle-visualizer": "^1.2.1",
    "vitest": "^4.0.8",
    "webpack-bundle-analyzer": "^4.10.2"
  }
}
